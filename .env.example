# 使用 openssl rand -hex 32 分别生成，切勿使用示例值上线。
SECRET_KEY=replace-with-64-random-hex
MASTER_KEY=replace-with-64-random-hex
DATABASE_URL=sqlite+aiosqlite:////app/data/vps-one.sqlite
# 首次安装回退地址；后台“站点公开地址”保存后覆盖。
BASE_URL=https://vps.example.com
DEBUG=false
VPS_ONE_PORT=9080

# 国内网络可取消注释；海外环境保持为空。
# PYTHON_IMAGE=docker.m.daocloud.io/python:3.12-slim
PYTHON_IMAGE=python:3.12-slim
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_INDEX_URL=

# CLICD、HashPay、SMTP 凭据请在首次安装后的“系统配置”页面填写，敏感值将加密保存。
